# ============================================================
# Harmony Living — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git.
# ============================================================

# --- Database ---
# Production / hosted Postgres (Neon, RDS, Supabase, etc.) — REQUIRES `sslmode=verify-full`.
# `verify-full` validates the server's TLS cert against the system CA bundle AND
# checks the hostname matches the cert. It's the only sslmode that defends against
# both eavesdropping AND active MITM. The weaker modes (`require`, `verify-ca`,
# `prefer`) are insecure and `pg` v9 deprecates them — see follow-up #1 in the
# Phase 2 review.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=verify-full"

# Local-development alternative (no SSL): for a Postgres running on your own
# machine, use a plain connection string with no `sslmode`. Do NOT use this in
# any deployed environment.
# DATABASE_URL="postgresql://harmony:harmony@localhost:5432/harmony_dev?schema=public"

# --- App ---
# NODE_ENV is set automatically by Next.js (next dev=development, next build=production).
# Do NOT set it manually — doing so is almost always a bug.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- AWS Cognito ---
# User Pool created in us-west-2 via the AWS Console "Traditional web app" quick-setup.
# App client is CONFIDENTIAL — it has a client secret (not a public client).
# All USER_PASSWORD_AUTH calls require a SECRET_HASH computed from the client secret.
COGNITO_USER_POOL_ID=""         # format: us-west-2_XXXXXXXXX
COGNITO_CLIENT_ID=""            # 26-char alphanumeric
COGNITO_CLIENT_SECRET=""        # confidential client secret — NEVER expose to browser
COGNITO_REGION="us-west-2"
COGNITO_DOMAIN=""               # full URL: https://<prefix>.auth.us-west-2.amazoncognito.com

# --- AWS S3 / IAM ---
# IAM user: harmony-living-dev (AmazonCognitoPowerUser + AmazonS3FullAccess)
# S3 bucket is set up in Phase 4 (file uploads). Keys work for Cognito admin calls now.
AWS_S3_BUCKET=""
AWS_S3_REGION="us-west-2"
AWS_ACCESS_KEY_ID=""            # AKIA...
AWS_SECRET_ACCESS_KEY=""

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=""     # set when map features are built (Phase 5+)

# --- Pusher / Realtime ---
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# --- Auth / Session ---
# Generate with: openssl rand -base64 32
# Must be at least 32 chars. Used to sign httpOnly session cookies.
AUTH_SECRET=""
