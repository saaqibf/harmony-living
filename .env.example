# ============================================================
# Harmony Living — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://harmony:harmony@localhost:5432/harmony_dev?schema=public"

# --- App ---
# NODE_ENV is set automatically by Next.js (next dev=development, next build=production).
# Do NOT set it manually — doing so is almost always a bug.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- AWS Cognito ---
COGNITO_USER_POOL_ID=""
COGNITO_CLIENT_ID=""
COGNITO_CLIENT_SECRET=""
COGNITO_REGION="us-east-1"
COGNITO_DOMAIN=""

# --- AWS S3 ---
AWS_S3_BUCKET=""
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=""

# --- Pusher ---
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# --- Auth / Session ---
AUTH_SECRET=""  # generate with: openssl rand -base64 32
